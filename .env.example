# Copy to .env and fill in. .env is gitignored.

# vast.ai API key — https://vast.ai/console/account
VAST_API_KEY=

# GHCR push (only needed for local cog push; CI uses GITHUB_TOKEN automatically)
# Personal access token with write:packages scope
GHCR_USER=neoevolutions
GHCR_TOKEN=

# Image to deploy (set after first GHA push)
GHCR_IMAGE=ghcr.io/neoevolutions/cog-zimage:phase0

# SSH key registered with vast.ai
SSH_KEY_PATH=~/.ssh/id_rsa_vastai
